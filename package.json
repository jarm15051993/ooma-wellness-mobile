{
  "name": "ooma-wellness-mobile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "EXPO_NO_DNSSD=1 expo start --dev-client",
    "android": "EXPO_NO_DNSSD=1 expo run:android --device",
    "ios": "EXPO_NO_DNSSD=1 expo run:ios --device",
    "web": "expo start --web",
    "build:android": "eas build --profile development --platform android",
    "build:ios": "eas build --profile development --platform ios"
  },
  "dependencies": {
    "@expo-google-fonts/cormorant-garamond": "^0.4.1",
    "@expo-google-fonts/montserrat": "^0.4.2",
    "@stripe/stripe-react-native": "^0.59.2",
    "axios": "^1.13.6",
    "date-fns": "^4.1.0",
    "expo": "~55.0.5",
    "expo-calendar": "~55.0.9",
    "expo-camera": "~55.0.9",
    "expo-constants": "~55.0.7",
    "expo-dev-client": "~55.0.16",
    "expo-file-system": "~55.0.10",
    "expo-font": "~55.0.4",
    "expo-image-picker": "~55.0.11",
    "expo-linking": "~55.0.7",
    "expo-notifications": "~55.0.11",
    "expo-router": "~55.0.4",
    "expo-secure-store": "~55.0.8",
    "expo-status-bar": "~55.0.4",
    "expo-web-browser": "^55.0.9",
    "react": "19.2.0",
    "react-dom": "^19.2.0",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
